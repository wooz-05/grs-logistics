{
  "name": "zenncore",
  "private": true,
  "author": {
    "name": "zennit",
    "email": "zennit.dev@gmail.com",
    "url": "https://www.zennit.dev/"
  },
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=./apps/web...",
    "build:mobile": "turbo run build --filter=./apps/mobile...",
    "build:packages": "turbo build --filter=@zenncore/*",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=./apps/web...",
    "dev:mobile": "turbo run dev --filter=./apps/mobile...",
    "dev:packages": "turbo dev --filter=@zenncore/*",
    "lint": "biome check --write",
    "typecheck": "turbo run typecheck",
    "outdated": "turbo run outdated && bun outdated -r",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@turbo/gen": "^2.9.14",
    "turbo": "^2.9.14"
  },
  "engines": {
    "node": ">=24",
    "bun": "^1.3.13"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "packages/shared/*"
    ],
    "catalog": {
      "@hookform/resolvers": "^5.2.2",
      "@tailwindcss/postcss": "^4.3.0",
      "@types/node": "^24.12.4",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.5",
      "react-hook-form": "^7.76.0",
      "tailwindcss": "^4.2.4",
      "tsdown": "^0.22.0",
      "typescript": "^6.0.3",
      "zod": "^4.4.3"
    },
    "catalogs": {
      "mobile": {
        "@types/react": "~19.2.15",
        "expo": "~55.0.25",
        "react": "19.2.0",
        "react-native": "0.83.6",
        "react-native-gesture-handler": "~2.30.0",
        "react-native-reanimated": "4.3.1",
        "react-native-teleport": "^1.1.6",
        "react-native-worklets": "0.8.3",
        "typescript": "~5.9.2",
        "uniwind": "^1.6.5"
      }
    }
  }
}
